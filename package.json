{
  "name": "@panwar-stack/agent-team",
  "version": "1.0.0",
  "description": "OpenCode plugin that enables multi-agent team orchestration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
